# Legacy peer-dep resolution required because vite-plugin-pwa@1.2.0 still
# peers against vite ^3..^7 while the rest of the toolchain (vite 8 +
# @vitejs/plugin-react which PEERS vite ^8) is on vite 8. Upgrading the plugin
# isn't available (no release supports vite 8) and downgrading vite breaks
# @vitejs/plugin-react. See VERCEL_BUILD_FIX_REPORT.md.
legacy-peer-deps=true
